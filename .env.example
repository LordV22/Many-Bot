# ==========================================================
# 🤖 Many Bot
# Environment Configuration
# ==========================================================

# ==========================================================
# APPLICATION
# ==========================================================
APP_NAME="🤖 Many Bot"
APP_ENV=development
APP_VERSION=1.0.0

HOST=0.0.0.0
PORT=8000

DEBUG=true

TIMEZONE=America/Sao_Paulo

LOG_LEVEL=INFO

SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET_KEY

JWT_SECRET=CHANGE_ME_GENERATE_ANOTHER_SECRET

JWT_EXPIRE_MINUTES=1440

# ==========================================================
# DATABASE
# ==========================================================

POSTGRES_HOST=postgres

POSTGRES_PORT=5432

POSTGRES_DB=manybot

POSTGRES_USER=manybot

POSTGRES_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql+asyncpg://manybot:CHANGE_ME@postgres:5432/manybot

# ==========================================================
# REDIS
# ==========================================================

REDIS_HOST=redis

REDIS_PORT=6379

REDIS_DB=0

REDIS_PASSWORD=

REDIS_URL=redis://redis:6379/0

# ==========================================================
# CACHE
# ==========================================================

CACHE_TTL=3600

CACHE_ENABLED=true

# ==========================================================
# SECURITY
# ==========================================================

ENABLE_RATE_LIMIT=true

ENABLE_GHOST_ENGINE=true

ENABLE_RISK_ENGINE=true

ENABLE_AUDIT_LOG=true

ENABLE_AUTO_BACKUP=true

ENABLE_AUTO_RECOVERY=true

ENABLE_HEALTHCHECK=true

# ==========================================================
# BACKUP
# ==========================================================

BACKUP_ENABLED=true

BACKUP_INTERVAL_MINUTES=60

BACKUP_KEEP_DAYS=30

# ==========================================================
# LOGGING
# ==========================================================

LOG_JSON=true

LOG_FILE=logs/manybot.log

# ==========================================================
# DASHBOARD
# ==========================================================

DASHBOARD_ENABLED=true

DASHBOARD_USERNAME=admin

DASHBOARD_PASSWORD=CHANGE_ME

# ==========================================================
# API
# ==========================================================

API_PREFIX=/api/v1

API_DOCS=true

# ==========================================================
# MANY AI
# ==========================================================

OPENAI_API_KEY=

GEMINI_API_KEY=

GROQ_API_KEY=

# ==========================================================
# WEATHER
# ==========================================================

OPENWEATHER_API_KEY=

# ==========================================================
# TRANSLATION
# ==========================================================

GOOGLE_TRANSLATE_API_KEY=

# ==========================================================
# GEOLOCATION
# ==========================================================

IPINFO_API_KEY=

# ==========================================================
# SENTRY
# ==========================================================

SENTRY_DSN=

# ==========================================================
# WHATSAPP
# ==========================================================
#
# Ainda NÃO será utilizado.
# O Gateway do WhatsApp será implementado
# na Sprint 2.
#
# ==========================================================

WHATSAPP_ENGINE=baileys

SESSION_NAME=manybot

AUTO_RECONNECT=true

HEARTBEAT_SECONDS=30
